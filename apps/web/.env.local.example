# ─────────────────────────────────────────────
# AnyGrade — environment variables
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to git.
# ─────────────────────────────────────────────

# ── Supabase ──────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

# Public URL of your Supabase project (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — used by the browser-side Supabase client (safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — has full DB access, bypasses RLS. NEVER expose to the browser.
# Used only in server-side routes (send-corrections, join, correct/[token]).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic ─────────────────────────────────
# Found in: console.anthropic.com → API Keys
# Used by all grading routes (grade, grade-omr, grade-cross, omr, extract-key,
# predict-key, extract-identity, detect-sheet, detect-batch, split-batch)
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend ────────────────────────────────────
# Found in: resend.com → API Keys
# Used by: /api/send-corrections to email graded papers to students
RESEND_API_KEY=re_...

# The "from" address on outgoing emails.
# During development, Resend's shared domain works without verification:
RESEND_FROM=AnyGrade <onboarding@resend.dev>
# In production, replace with your verified domain:
# RESEND_FROM=AnyGrade <grades@yourdomain.com>

# ── App URL ───────────────────────────────────
# The public URL of the app — used to build the /correct/[token] link in emails.
# Local development:
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production (set this in Vercel environment variables, not here):
# NEXT_PUBLIC_APP_URL=https://anygrade.vercel.app

# Same as above but used in login magic link redirect.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── OpenAI (seed script only) ─────────────────
# Found in: platform.openai.com → API Keys
# Used ONLY by: scripts/seed-cmo-topics.ts to generate embeddings for CHED topics.
# Not needed for normal app operation.
OPENAI_API_KEY=sk-...
